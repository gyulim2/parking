# DB 접속 정보 — 본인 환경에 맞게 수정 후 .env 로 복사
# ※ MySQL/MariaDB 비밀번호가 있으면 DB_PASSWORD 에 입력

# ── MySQL (비밀번호 있는 경우) ──────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=여기에_비밀번호
DB_NAME=parking_db

# ── Mac Homebrew MariaDB (비밀번호 없는 경우) ────
# DB_USER=본인_맥_계정명
# DB_PASSWORD=
# DB_NAME=parking_db
# DB_SOCKET=/tmp/mysql.sock

# Flask
FLASK_SECRET_KEY=아무_랜덤_문자열_입력

# 관리자 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
