# DB 접속 정보 — 본인 환경에 맞게 수정 후 .env 로 복사
# ※ 00_mysql_users.sql 실행 후 아래 비밀번호를 본인이 설정한 값으로 변경

# ── 관리자용 DB 계정 (통계, 수정 등 전체 권한) ──────────────
DB_ADMIN_USER=parking_admin
DB_ADMIN_PASSWORD=admin_pw_여기수정

# ── 일반용 DB 계정 (입차/출차, 조회 전용) ────────────────────
DB_USER=parking_user
DB_PASSWORD=user_pw_여기수정

# ── 공통 DB 접속 정보 ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=parking_db

# ── Mac Homebrew MariaDB (소켓 방식) ─────────────────────────
# DB_SOCKET=/tmp/mysql.sock

# ── Flask ────────────────────────────────────────────────────
FLASK_SECRET_KEY=아무_랜덤_문자열_입력
